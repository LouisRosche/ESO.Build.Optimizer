    {
      "id": "ttc-001",
      "name": "TamrielTradeCentre",
      "category": "pricing_library",
      "confidence": 0.85,
      "notes": "The correct global object for price queries is TamrielTradeCentrePrice, NOT TamrielTradeCentre. Calling TamrielTradeCentre:GetPriceInfo() will error. Use TamrielTradeCentrePrice:GetPriceInfo(itemLink).",
      "correctCall": "TamrielTradeCentrePrice:GetPriceInfo(itemLink)",
      "incorrectCall": "TamrielTradeCentre:GetPriceInfo(itemLink)",
      "returnType": "TamrielTradeCentre_PriceInfo table or nil",
      "returnFields": {
        "Avg": "number - average listing price",
        "Max": "number - maximum listing price",
        "Min": "number - minimum listing price",
        "EntryCount": "number - count of listings seen",
        "AmountCount": "number - total items in listings",
        "SuggestedPrice": "number - suggested low price (multiply by 1.25 for high)",
        "SaleAvg": "number - average from completed sales",
        "SaleEntryCount": "number - count of sales recorded",
        "SaleAmountCount": "number - total items sold"
      },
      "source": "https://www.esoui.com/downloads/info1245-TamrielTradeCentre.html"
    },
    {
      "id": "mm-001",
      "name": "MasterMerchant",
      "category": "pricing_library",
      "confidence": 0.4,
      "notes": "MasterMerchant source is not publicly available on GitHub. The function ItemPriceByItemLink exists per community reports but exact return table structure requires inspection of the installed addon's .lua files. Likely returns a table with avgPrice, numEntries, minPrice, maxPrice fields or nil if no data.",
      "correctCall": "MasterMerchant:ItemPriceByItemLink(itemLink)",
      "returnType": "table or nil (structure unverified without source access)",
      "source": "Community knowledge - inspect addon source at: Documents/Elder Scrolls Online/live/AddOns/MasterMerchant/"
    }
  ],

